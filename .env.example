# --- Postgres (Prisma lives in backend/prisma/) ---
# Put this in repo root `.env` or `.env.prod` — Prisma / backend / Next load both, then optional `.env.local` (see frontend/next.config.ts).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/plansync"
# Local Docker Postgres (`docker compose up -d` from repo root) matches the URL above. If `.env` points at a remote DB,
# add repo root `.env.local` (gitignored) with only:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/plansync"
# Prisma: local uses `.env.local` (e.g. `npm run db:local:studio`). Prod / remote without `.env.local`: `npm run db:prod:migrate:deploy` (sets PRISMA_SKIP_LOCAL).
# Existing DB (tables from db push) but migrate deploy fails with P3005 "schema is not empty":
#   1) npm run db:drift-to-schema -w backend   (apply printed SQL if any)
#   2) npm run db:migrate:baseline -w backend  (mark init migration applied; does not re-run CREATE TABLE)
#   3) npm run db:migrate:deploy -w backend

# --- Hono API (backend) — copy to backend/.env or export before `npm run dev:backend` ---
PORT=8787
BETTER_AUTH_SECRET="replace-with-32-char-min-secret-string"
BETTER_AUTH_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
# Used for invite links (`/join/...`) in emails and the admin UI — set to your real app URL in production.
PUBLIC_APP_URL="http://localhost:3000"
# When the SPA (or Mintlify) calls the API on another host, set both (same value, no trailing slash):
# NEXT_PUBLIC_API_URL=https://api.plansync.dev
# PUBLIC_API_URL=https://api.plansync.dev
# Required with split API host so session cookies work on api.* + app origin:
# BETTER_AUTH_COOKIE_DOMAIN=plansync.dev
# Optional: comma-separated extra Origins for CORS + Better Auth (e.g. Mintlify preview domain)
# CORS_EXTRA_ORIGINS=

# OAuth (optional) — add the same vars to backend/.env. Redirect URLs must include:
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/github
#   http://localhost:3000/api/auth/callback/slack
# (replace origin in production.) Sign-in shows Google / GitHub / Slack by default; set to hide:
# NEXT_PUBLIC_SOCIAL_AUTH=none
# Or restrict: NEXT_PUBLIC_SOCIAL_AUTH=google,github
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# AWS S3 (optional — without it, presign returns 503 with dev hints)
# Create a private bucket + IAM user (PutObject/GetObject). Configure S3 CORS for your
# app origin so browser uploads work — see docs/s3-setup.md
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Optional: max bytes for POST /api/v1/files/upload (default 104857600 = 100 MiB). Larger files use presigned PUT (needs S3 CORS).
# MAX_DIRECT_UPLOAD_BYTES=104857600

# Stripe (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_MONTHLY=price_xxx

# Resend (optional — storage alerts still log activity without it; required in production for “forgot password” emails)
# RESEND_API_KEY=
# RESEND_FROM="PlanSync <onboarding@resend.dev>"

# Sheet AI — Google Gemini (optional; viewer “AI” tab returns 503 if unset)
# GEMINI_API_KEY=
# Or: GOOGLE_GENERATIVE_AI_API_KEY=
# Default in code is gemini-2.5-pro (sharper summaries/TOC). Cheaper/faster: gemini-2.5-flash or gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-pro

# --- Next (prefer repo root `.env.prod`; optional frontend/.env for overrides) ---
# API_PROXY_TARGET=http://127.0.0.1:8787
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SOCIAL_AUTH=google,github,slack
