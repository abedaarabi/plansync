// PlanSync Pro — Postgres. Run: npm run db:generate -w backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Better Auth (core) — keep in sync with better-auth prisma adapter ---

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]

  workspaceMembers WorkspaceMember[]
  projectMembers   ProjectMember[]
  emailInvitesSent EmailInvite[] @relation("EmailInviteInviter")
  activityLogs     ActivityLog[] @relation("ActivityActor")
  issuesAssigned   Issue[]       @relation("IssueAssignee")
  issuesCreated    Issue[]       @relation("IssueCreator")
  fileVersions     FileVersion[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- PlanSync domain ---

model Workspace {
  id     String @id @default(cuid())
  name   String
  slug   String @unique

  /// Public org branding (dashboard, invites, sidebar)
  logoUrl     String?
  description String?
  website     String?

  /// bytes — default 10 GiB (plan allows 20GB or overage later)
  storageQuotaBytes BigInt @default(10737418240)
  storageUsedBytes  BigInt @default(0)

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  subscriptionStatus   String? // active | canceled | past_due | trialing | incomplete | null = free/manual
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   WorkspaceMember[]
  invites   WorkspaceInvite[]
  emailInvites EmailInvite[]
  projects  Project[]
  activity  ActivityLog[]
  issues    Issue[]

  materialCategories MaterialCategory[]
  materials          Material[]
  takeoffLines       TakeoffLine[]
}

/// Grouping label (e.g. Concrete, Steel, Finishes). Unique per workspace (case-insensitive via nameKey).
model MaterialCategory {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  nameKey     String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  materials   Material[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, nameKey])
  @@index([workspaceId])
}

/// Workspace materials catalog (for estimates, takeoff references, procurement).
model Material {
  id            String   @id @default(cuid())
  workspaceId   String
  categoryId    String
  name          String
  nameKey       String
  sku           String?
  unit          String   @default("ea")
  unitPrice     Decimal? @db.Decimal(19, 2)
  currency      String   @default("USD")
  supplier      String?
  manufacturer  String?
  specification String?
  notes         String?
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category      MaterialCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  takeoffLines  TakeoffLine[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([workspaceId, categoryId, nameKey])
  @@index([workspaceId])
  @@index([categoryId])
}

/// Shareable join link (admin-generated). Anyone with the link can sign up / sign in and join as MEMBER until revoked, expired, or workspace is full.
model WorkspaceInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

enum WorkspaceRole {
  ADMIN
  MEMBER
}

/// 1 admin + up to 3 members = 4 (product rule; enforce in API)
model WorkspaceMember {
  id          String @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

/// Per-project access. If a user has no rows here for a workspace, they see all projects (legacy).
model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

/// Email invite with optional project scope (Resend). Accepted users become workspace members + ProjectMember rows when scoped.
model EmailInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  invitedById String
  invitedBy   User      @relation("EmailInviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(MEMBER)
  expiresAt   DateTime
  revokedAt   DateTime?
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  projects EmailInviteProject[]

  @@index([workspaceId])
  @@index([email])
}

model EmailInviteProject {
  emailInviteId String
  projectId     String
  emailInvite   EmailInvite @relation(fields: [emailInviteId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([emailInviteId, projectId])
  @@index([projectId])
}

/// High-level lifecycle for scheduling and reporting (independent of `progressPercent`).
enum ProjectStage {
  NOT_STARTED
  PLANNING
  PRECONSTRUCTION
  CONSTRUCTION
  CLOSEOUT
  COMPLETED
  ON_HOLD
}

model Project {
  id          String @id @default(cuid())
  workspaceId String
  name        String

  /// Client or internal job reference (e.g. contract #).
  projectNumber String?
  /// Local currency budget amount.
  localBudget   Decimal? @db.Decimal(19, 2)
  /// e.g. square footage, floors, or scope summary.
  projectSize String?
  /// e.g. Commercial, Residential, Infrastructure.
  projectType String?
  /// Site or city (optional).
  location  String?
  /// Project or client website (https). Used to resolve a favicon for the project logo.
  websiteUrl String?
  /// Cached favicon image URL (typically Google favicons service for `websiteUrl` hostname).
  logoUrl    String?

  stage           ProjectStage @default(NOT_STARTED)
  /// Overall completion 0–100 (manual; not tied strictly to `stage`).
  progressPercent Int          @default(0)
  /// Planned project start date.
  startDate       DateTime?
  /// Planned project end date.
  endDate         DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectMembers ProjectMember[]
  emailInviteProjects EmailInviteProject[]
  folders   Folder[]
  files     File[]
  issues    Issue[]
  takeoffLines TakeoffLine[]
  rfis      Rfi[]
  punchItems PunchItem[]
  fieldReports FieldReport[]
  auditLogs ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model Folder {
  id        String @id @default(cuid())
  projectId String
  name      String
  parentId  String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent  Folder? @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Folder[] @relation("FolderTree")
  files   File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model File {
  id        String @id @default(cuid())
  projectId String
  folderId  String?
  /// Same as `folderId` when set; `""` when file is in project root (enforces one logical file per name per folder).
  folderKey String @default("")
  name      String
  mimeType  String @default("application/pdf")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  versions FileVersion[]
  issues   Issue[]
  takeoffLines TakeoffLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Last time the file was opened in the viewer (any version)
  lastOpenedAt DateTime?

  @@unique([projectId, name, folderKey])
  @@index([projectId])
}

model FileVersion {
  id          String @id @default(cuid())
  fileId      String
  version     Int
  s3Key       String
  sizeBytes   BigInt
  sha256      String?
  label       String?
  uploadedById String?

  file       File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  annotationBlob Json? /// persisted Zustand-compatible annotation JSON per version
  lockedByUserId String?
  lockedAt       DateTime?
  lockExpiresAt  DateTime?

  createdAt DateTime @default(now())
  issues    Issue[]
  takeoffLines TakeoffLine[]

  @@unique([fileId, version])
  @@index([fileId])
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
}

model Issue {
  id            String @id @default(cuid())
  workspaceId   String
  projectId     String
  fileId        String
  fileVersionId String

  title       String
  description String?
  status      IssueStatus @default(OPEN)
  priority    IssuePriority @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  /// Free-text location (e.g. grid / zone), PlanGrid-style.
  location    String?

  /// Denormalized sheet identity (refreshed on create/update from File / FileVersion).
  sheetName    String?
  sheetVersion Int?
  /// 1-based PDF page for the issue pin.
  pageNumber   Int?

  /// viewer annotation id(s) — store primary
  annotationId String?

  assigneeId String?
  creatorId  String?

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file       File       @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileVersion FileVersion @relation(fields: [fileVersionId], references: [id], onDelete: Cascade)
  assignee   User?      @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator    User?      @relation("IssueCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([projectId])
  @@index([fileId])
  @@index([fileVersionId])
}

/// Quantity takeoff line for a specific sheet revision (Pro).
model TakeoffLine {
  id            String @id @default(cuid())
  workspaceId   String
  projectId     String
  fileId        String
  fileVersionId String
  materialId    String?
  label         String @default("")
  quantity      Decimal @db.Decimal(19, 4)
  unit          String  @default("ea")
  notes         String?
  /// Viewer zone id for upsert when publishing quantities from the sheet.
  sourceZoneId  String?
  tags          String[] @default([])

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file        File        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileVersion FileVersion @relation(fields: [fileVersionId], references: [id], onDelete: Cascade)
  material    Material?   @relation(fields: [materialId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fileVersionId, sourceZoneId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([fileId])
  @@index([fileVersionId])
}

enum RfiStatus {
  OPEN
  IN_REVIEW
  ANSWERED
  CLOSED
}

model Rfi {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      RfiStatus @default(OPEN)
  fromDiscipline String?
  dueDate     DateTime?
  risk        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}

enum PunchPriority {
  P1
  P2
  P3
}

enum PunchStatus {
  OPEN
  IN_PROGRESS
  READY_FOR_GC
  CLOSED
}

model PunchItem {
  id          String        @id @default(cuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  location    String
  trade       String
  priority    PunchPriority @default(P2)
  status      PunchStatus   @default(OPEN)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([projectId])
}

model FieldReport {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportDate  DateTime
  weather     String?
  authorLabel String?
  photoCount  Int      @default(0)
  issueCount  Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

enum ActivityType {
  WORKSPACE_CREATED
  MEMBER_INVITED
  MEMBER_REMOVED
  PROJECT_CREATED
  FOLDER_CREATED
  FOLDER_DELETED
  FILE_UPLOADED
  FILE_VERSION_ADDED
  FILE_DELETED
  FILE_MOVED
  FOLDER_MOVED
  FILE_OPENED
  ISSUE_CREATED
  ISSUE_UPDATED
  ISSUE_DELETED
  RFI_CREATED
  RFI_UPDATED
  PUNCH_CREATED
  PUNCH_UPDATED
  FIELD_REPORT_CREATED
  FIELD_REPORT_UPDATED
  FIELD_REPORT_DELETED
  RFI_DELETED
  PUNCH_DELETED
  PROJECT_UPDATED
  SUBSCRIPTION_UPDATED
  STORAGE_THRESHOLD
}

model ActivityLog {
  id          String @id @default(cuid())
  workspaceId String
  /// When set, this event is scoped to a project (audit log / export).
  projectId   String?
  actorUserId String?
  type        ActivityType
  entityType  String?
  entityId    String?
  metadata    Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  actor     User?     @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([projectId, createdAt])
}

/// Idempotent Stripe webhook processing
model ProcessedStripeEvent {
  eventId   String   @id
  createdAt DateTime @default(now())
}
