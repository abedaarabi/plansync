// PlanSync Pro — Postgres. Run: npm run db:generate -w backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Better Auth (core) — keep in sync with better-auth prisma adapter ---

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  workspaceMembers        WorkspaceMember[]
  projectMembers          ProjectMember[]
  emailInvitesSent        EmailInvite[]            @relation("EmailInviteInviter")
  activityLogs            ActivityLog[]            @relation("ActivityActor")
  issuesAssigned          Issue[]                  @relation("IssueAssignee")
  issuesCreated           Issue[]                  @relation("IssueCreator")
  fileVersions            FileVersion[]
  rfisCreated             Rfi[]                    @relation("RfiCreator")
  rfisAssigned            Rfi[]                    @relation("RfiAssignee")
  rfiAssigneeLinks        RfiAssigneeLink[]
  rfiAttachments          RfiAttachment[]          @relation("RfiAttachmentUploader")
  assetDocumentsUploaded  AssetDocument[]          @relation("AssetDocumentUploader")
  rfiMessages             RfiMessage[]             @relation("RfiMessageAuthor")
  notifications           UserNotification[]       @relation("NotificationRecipient")
  notificationsAsActor    UserNotification[]       @relation("NotificationActor")
  proposalsCreated        Proposal[]               @relation("ProposalCreator")
  cloudStorageConnections CloudStorageConnection[]
  punchItemsAssigned      PunchItem[]              @relation("PunchAssignee")
  punchTemplatesCreated   PunchTemplate[]          @relation("PunchTemplateCreator")
  punchHistoryActions     PunchItemHistory[]
  inspectionRunsSignedOff InspectionRun[]          @relation("InspectionRunSignedOff")
  inspectionRunsCreated   InspectionRun[]          @relation("InspectionRunCreated")
  takeoffViewPresets      TakeoffViewPreset[]
  takeoffSyncRuns         TakeoffSyncRun[]
  takeoffSnapshots        TakeoffSnapshot[]

  /// When true, omit this user from PDF viewer presence / collaborator lists (still can edit).
  hideViewerPresence Boolean @default(false)
}

enum CloudStorageProvider {
  GOOGLE_DRIVE
  ONEDRIVE
  DROPBOX
}

/// OAuth tokens for importing files from Google Drive / OneDrive / Dropbox (per user).
model CloudStorageConnection {
  id       String               @id @default(cuid())
  userId   String
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider CloudStorageProvider

  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  /// e.g. email or display name from the provider
  accountLabel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- PlanSync domain ---

model Workspace {
  id   String @id @default(cuid())
  name String
  slug String @unique

  /// Public org branding (dashboard, invites, sidebar, proposals)
  logoUrl      String?
  /// Uploaded logo in S3 (`ws/{id}/branding/logo`); served via GET /public/workspaces/:id/logo
  logoS3Key    String?
  description  String?
  website      String?
  /// Brand accent for org settings + client portal (hex, e.g. #2563EB)
  primaryColor String  @default("#2563EB")

  /// Super-admin-defined custom material catalog fields (JSON: { version, fields: [...] }).
  materialTemplateJson Json @default("{}")

  /// bytes — default 10 GiB (plan allows 20GB or overage later)
  storageQuotaBytes BigInt @default(10737418240)
  storageUsedBytes  BigInt @default(0)

  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String? // active | canceled | past_due | trialing | incomplete | null = free/manual
  currentPeriodEnd     DateTime?
  /// Paid tier from Stripe Checkout metadata / subscription items: `pro` | `enterprise`. Null = legacy (pre–plan split) or unknown.
  billingPlan          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        WorkspaceMember[]
  invites        WorkspaceInvite[]
  emailInvites   EmailInvite[]
  projects       Project[]
  activity       ActivityLog[]
  issues         Issue[]
  punchTemplates PunchTemplate[]

  materialCategories MaterialCategory[]
  materials          Material[]
  takeoffLines       TakeoffLine[]
  takeoffViewPresets TakeoffViewPreset[]
  takeoffSyncRuns    TakeoffSyncRun[]
  takeoffSnapshots   TakeoffSnapshot[]
  userNotifications  UserNotification[]
  proposalTemplates  ProposalTemplate[]
  proposals          Proposal[]

  /// PDF viewer live collaboration (SSE/WebSocket rooms). Env COLLABORATION_ENABLED must also allow.
  viewerCollaborationEnabled Boolean @default(true)

  /// Daily O&M maintenance digest emails — idempotency (one row per workspace per UTC day).
  omMaintenanceReminderDigests OmMaintenanceReminderDigest[]
}

/// Tracks POST /internal/om-maintenance-reminders digest already sent for a workspace/day (UTC).
model OmMaintenanceReminderDigest {
  id          String   @id @default(cuid())
  workspaceId String
  /// UTC calendar date YYYY-MM-DD.
  digestDate  String
  sentAt      DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, digestDate])
  @@index([digestDate])
}

/// Grouping label (e.g. Concrete, Steel, Finishes). Unique per workspace (case-insensitive via nameKey).
model MaterialCategory {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  nameKey     String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  materials   Material[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([workspaceId, nameKey])
  @@index([workspaceId])
}

/// Workspace materials catalog (for estimates, takeoff references, procurement).
model Material {
  id               String           @id @default(cuid())
  workspaceId      String
  categoryId       String
  name             String
  nameKey          String
  sku              String?
  unit             String           @default("ea")
  unitPrice        Decimal?         @db.Decimal(19, 2)
  currency         String           @default("USD")
  supplier         String?
  manufacturer     String?
  specification    String?
  notes            String?
  /// Values for workspace custom material fields; keys match MaterialTemplateField.key.
  customAttributes Json             @default("{}")
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category         MaterialCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  takeoffLines     TakeoffLine[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([workspaceId, categoryId, nameKey])
  @@index([workspaceId])
  @@index([categoryId])
}

/// Shareable join link (admin-generated). Anyone with the link can sign up / sign in and join as MEMBER until revoked, expired, or workspace is full.
model WorkspaceInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

enum WorkspaceRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

/// 1 admin + up to 3 members = 4 (product rule; enforce in API)
model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  /// External collaborators (client, contractor, sub) do not consume paid seats.
  isExternal  Boolean       @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum ProjectMemberRole {
  INTERNAL
  CLIENT
  CONTRACTOR
  SUBCONTRACTOR
}

/// Per-project access. If a user has no rows here for a workspace, they see all projects (legacy).
model ProjectMember {
  id          String            @id @default(cuid())
  projectId   String
  userId      String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// INTERNAL = team; external roles for client portal / contractor views.
  projectRole ProjectMemberRole @default(INTERNAL)
  /// Trade label for contractor/sub (e.g. Electrical, Plumbing).
  trade       String?

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

enum EmailInviteKind {
  INTERNAL
  CLIENT
  CONTRACTOR
  SUBCONTRACTOR
}

/// Email invite with optional project scope (Resend). Accepted users become workspace members + ProjectMember rows when scoped.
model EmailInvite {
  id             String          @id @default(cuid())
  token          String          @unique
  workspaceId    String
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email          String
  invitedById    String
  invitedBy      User            @relation("EmailInviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  role           WorkspaceRole   @default(MEMBER)
  /// Workspace role for internal invites; external invites use isExternal on membership at accept time.
  inviteKind     EmailInviteKind @default(INTERNAL)
  trade          String?
  inviteeName    String?
  inviteeCompany String?
  expiresAt      DateTime
  revokedAt      DateTime?
  acceptedAt     DateTime?
  createdAt      DateTime        @default(now())

  projects EmailInviteProject[]

  @@index([workspaceId])
  @@index([email])
}

model EmailInviteProject {
  emailInviteId String
  projectId     String
  emailInvite   EmailInvite @relation(fields: [emailInviteId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([emailInviteId, projectId])
  @@index([projectId])
}

/// High-level lifecycle for scheduling and reporting (independent of `progressPercent`).
enum ProjectStage {
  NOT_STARTED
  PLANNING
  PRECONSTRUCTION
  CONSTRUCTION
  CLOSEOUT
  /// Building / FM handover (warranty, training, asset register, O&M).
  HANDOVER
  COMPLETED
  ON_HOLD
}

/// Length / area display for measurements and takeoff defaults (metric vs US customary).
enum ProjectMeasurementSystem {
  METRIC
  IMPERIAL
}

model Project {
  id          String @id @default(cuid())
  workspaceId String
  name        String

  /// Client or internal job reference (e.g. contract #).
  projectNumber     String?
  /// ISO 4217 (e.g. USD, DKK). Used for budget and cost display.
  currency          String                   @default("USD")
  /// Metric (m, m²) vs imperial (ft, ft²) for the project.
  measurementSystem ProjectMeasurementSystem @default(METRIC)

  /// Local currency budget amount.
  localBudget Decimal? @db.Decimal(19, 2)
  /// e.g. square footage, floors, or scope summary.
  projectSize String?
  /// e.g. Commercial, Residential, Infrastructure.
  projectType String?
  /// Site or city (optional).
  location    String?
  /// Map pin (WGS84). Both set or both null.
  latitude    Float?
  longitude   Float?

  /// Project or client website (https). Used to resolve a favicon for the project logo.
  websiteUrl String?
  /// Cached favicon image URL (typically Google favicons service for `websiteUrl` hostname).
  logoUrl    String?

  stage           ProjectStage @default(NOT_STARTED)
  /// Overall completion 0–100 (manual; not tied strictly to `stage`).
  progressPercent Int          @default(0)
  /// Planned project start date.
  startDate       DateTime?
  /// Planned project end date.
  endDate         DateTime?

  /// Module/feature toggles + client visibility (null = all enabled for backwards compatibility).
  settingsJson Json?

  /// Operations & Maintenance: enables O&M nav, assets, PPM, inspections, occupant portal (when modules allow).
  operationsMode Boolean @default(false)

  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectMembers       ProjectMember[]
  emailInviteProjects  EmailInviteProject[]
  folders              Folder[]
  files                File[]
  issues               Issue[]
  takeoffLines         TakeoffLine[]
  takeoffViewPresets   TakeoffViewPreset[]
  takeoffSyncRuns      TakeoffSyncRun[]
  takeoffSnapshots     TakeoffSnapshot[]
  rfis                 Rfi[]
  punchItems           PunchItem[]
  punchTemplates       PunchTemplate[]
  fieldReports         FieldReport[]
  auditLogs            ActivityLog[]
  userNotifications    UserNotification[]
  proposals            Proposal[]
  assets               Asset[]
  inspectionTemplates  InspectionTemplate[]
  inspectionRuns       InspectionRun[]
  occupantPortalTokens OccupantPortalToken[]
  scheduleTasks        ScheduleTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

/// Construction schedule row (WBS-style hierarchy + Gantt dates).
model ScheduleTask {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title    String
  parentId String?
  parent   ScheduleTask?  @relation("ScheduleTaskTree", fields: [parentId], references: [id], onDelete: Cascade)
  children ScheduleTask[] @relation("ScheduleTaskTree")

  sortOrder Int @default(0)

  /// Date-only semantics; stored UTC noon to avoid TZ drift (see issues routes).
  startDate DateTime
  endDate   DateTime

  isMilestone     Boolean @default(false)
  progressPercent Int     @default(0)
  status          String  @default("not_started")

  takeoffLinks ScheduleTaskTakeoffLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([parentId])
}

/// Many-to-many: schedule task ↔ quantity takeoff lines (materials / measured lines).
model ScheduleTaskTakeoffLine {
  scheduleTaskId String
  takeoffLineId  String

  scheduleTask ScheduleTask @relation(fields: [scheduleTaskId], references: [id], onDelete: Cascade)
  takeoffLine  TakeoffLine  @relation(fields: [takeoffLineId], references: [id], onDelete: Cascade)

  @@id([scheduleTaskId, takeoffLineId])
  @@index([takeoffLineId])
}

model Folder {
  id        String  @id @default(cuid())
  projectId String
  name      String
  parentId  String?

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Folder[] @relation("FolderTree")
  files    File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

/// Folder tree presets (empty folders only). Listed and applied from DB so edits take effect without redeploy.
model FolderStructureTemplate {
  slug        String   @id
  name        String
  description String
  tree        Json /// [{ "name": string, "children"?: ... }]
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model File {
  id          String   @id @default(cuid())
  projectId   String
  folderId    String?
  /// Same as `folderId` when set; `""` when file is in project root (enforces one logical file per name per folder).
  folderKey   String   @default("")
  name        String
  mimeType    String   @default("application/pdf")
  /// Discipline tags for contractor filtering (e.g. Electrical, Plumbing). Empty = not tagged.
  disciplines String[] @default([])

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  versions       FileVersion[]
  issues         Issue[]
  takeoffLines   TakeoffLine[]
  rfisDrawing    Rfi[]           @relation("RfiDrawingFile")
  assets         Asset[]
  inspectionRuns InspectionRun[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  /// Last time the file was opened in the viewer (any version)
  lastOpenedAt DateTime?

  @@unique([projectId, name, folderKey])
  @@index([projectId])
}

model FileVersion {
  id           String  @id @default(cuid())
  fileId       String
  version      Int
  s3Key        String
  sizeBytes    BigInt
  sha256       String?
  label        String?
  uploadedById String?

  file       File  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  annotationBlob         Json? /// persisted Zustand-compatible annotation JSON per version
  /// Incremented on each successful viewer-state PUT (multi-user sync + conflict detection).
  annotationBlobRevision Int       @default(0)
  /// Sheet AI: cached smart sheet + chat per PDF page (see `sheetAiCache` shape in backend).
  sheetAiCache           Json?
  lockedByUserId         String?
  lockedAt               DateTime?
  lockExpiresAt          DateTime?

  createdAt              DateTime                @default(now())
  issues                 Issue[]
  takeoffLines           TakeoffLine[]
  rfisDrawing            Rfi[]                   @relation("RfiDrawingVersion")
  proposalTakeoffSources ProposalTakeoffSource[]
  proposalAttachments    ProposalAttachment[]
  assets                 Asset[]
  inspectionRuns         InspectionRun[]

  @@unique([fileId, version])
  @@index([fileId])
}

enum IssueKind {
  CONSTRUCTION
  WORK_ORDER
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
}

model Issue {
  id            String @id @default(cuid())
  workspaceId   String
  projectId     String
  fileId        String
  fileVersionId String

  title       String
  description String?
  status      IssueStatus   @default(OPEN)
  priority    IssuePriority @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  /// Free-text location (e.g. grid / zone), PlanGrid-style.
  location    String?

  /// Denormalized sheet identity (refreshed on create/update from File / FileVersion).
  sheetName    String?
  sheetVersion Int?
  /// 1-based PDF page for the issue pin.
  pageNumber   Int?

  /// viewer annotation id(s) — store primary
  annotationId String?

  /// Additional sheet markup annotation ids linked to this issue (same file version blob); not the location pin.
  attachedMarkupAnnotationIds Json?

  /// Reference images (S3) attached to the issue; optional per-item `sketch` JSON for on-image markups.
  referencePhotos Json?

  /// Optional BIM / 3D anchor payload for sheet ↔ model linking.
  bimAnchor Json?

  assigneeId String?
  creatorId  String?

  issueKind IssueKind @default(CONSTRUCTION)
  assetId   String?
  asset     Asset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)

  /// When assignee is not a workspace user (e.g. external vendor).
  externalAssigneeEmail String?
  externalAssigneeName  String?

  acknowledgedAt DateTime?
  resolvedAt     DateTime?

  /// Occupant / portal submitter (when created via tenant portal).
  reporterName  String?
  reporterEmail String?

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file        File        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileVersion FileVersion @relation(fields: [fileVersionId], references: [id], onDelete: Cascade)
  assignee    User?       @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator     User?       @relation("IssueCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rfiLinks RfiIssueLink[]

  @@index([workspaceId])
  @@index([projectId])
  @@index([fileId])
  @@index([fileVersionId])
  @@index([assetId])
  @@index([issueKind])
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  CUSTOM
}

/// Equipment register for O&M (pinned on drawings when fileVersion is set).
model Asset {
  id              String    @id @default(cuid())
  projectId       String
  tag             String
  name            String
  /// e.g. HVAC, Electrical (free text).
  category        String?
  manufacturer    String?
  model           String?
  serialNumber    String?
  locationLabel   String?
  installDate     DateTime?
  warrantyExpires DateTime?
  lastServiceAt   DateTime?
  notes           String?

  fileId        String?
  fileVersionId String?
  pageNumber    Int?
  annotationId  String?
  pinJson       Json?

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file        File?        @relation(fields: [fileId], references: [id], onDelete: SetNull)
  fileVersion FileVersion? @relation(fields: [fileVersionId], references: [id], onDelete: SetNull)

  issues               Issue[]
  maintenanceSchedules MaintenanceSchedule[]
  documents            AssetDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, tag])
  @@index([projectId])
}

/// Files attached to an asset (manuals, certificates) — stored in S3, not project drawings.
model AssetDocument {
  id           String   @id @default(cuid())
  assetId      String
  /// Display name e.g. "Manufacturer manual".
  label        String   @default("")
  fileName     String
  mimeType     String   @default("application/octet-stream")
  s3Key        String   @unique
  sizeBytes    BigInt
  uploadedById String?
  uploadedBy   User?    @relation("AssetDocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([assetId])
}

model MaintenanceSchedule {
  id                  String               @id @default(cuid())
  assetId             String
  title               String               @default("")
  frequency           MaintenanceFrequency
  /// Used when frequency is CUSTOM (e.g. every N days).
  intervalDays        Int?
  nextDueAt           DateTime?
  lastCompletedAt     DateTime?
  assignedVendorLabel String?
  isActive            Boolean              @default(true)

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([nextDueAt])
}

model InspectionTemplate {
  id            String  @id @default(cuid())
  projectId     String
  name          String
  description   String?
  /// Display frequency label (e.g. "Monthly", "Weekly", "Annual").
  frequency     String?
  checklistJson Json

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    InspectionRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

enum InspectionRunStatus {
  DRAFT
  COMPLETED
}

model InspectionRun {
  id              String              @id @default(cuid())
  projectId       String
  templateId      String
  fileId          String?
  fileVersionId   String?
  pageNumber      Int?
  status          InspectionRunStatus @default(DRAFT)
  resultJson      Json                @default("[]")
  attachmentsJson Json                @default("[]")
  completedAt     DateTime?
  signedOffById   String?
  createdById     String?

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template    InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  file        File?              @relation(fields: [fileId], references: [id], onDelete: SetNull)
  fileVersion FileVersion?       @relation(fields: [fileVersionId], references: [id], onDelete: SetNull)
  signedOffBy User?              @relation("InspectionRunSignedOff", fields: [signedOffById], references: [id], onDelete: SetNull)
  createdBy   User?              @relation("InspectionRunCreated", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([templateId])
}

/// Public magic-link access for occupant portal (submit requests without login).
model OccupantPortalToken {
  id        String    @id @default(cuid())
  projectId String
  token     String    @unique
  label     String    @default("Default")
  expiresAt DateTime?
  revokedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

/// Quantity takeoff line for a specific sheet revision (Pro).
model TakeoffLine {
  id                        String   @id @default(cuid())
  workspaceId               String
  projectId                 String
  fileId                    String
  fileVersionId             String
  materialId                String?
  label                     String   @default("")
  quantity                  Decimal  @db.Decimal(19, 4)
  unit                      String   @default("ea")
  notes                     String?
  sourceType                String   @default("zone")
  /// Source file version at time of creation, used for mismatch warnings when revisions move.
  sourceFileVersionAtCreate Int?
  /// Viewer zone id for upsert when publishing quantities from the sheet.
  sourceZoneId              String?
  tags                      String[] @default([])

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file        File        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileVersion FileVersion @relation(fields: [fileVersionId], references: [id], onDelete: Cascade)
  material    Material?   @relation(fields: [materialId], references: [id], onDelete: SetNull)

  scheduleTaskLinks ScheduleTaskTakeoffLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fileVersionId, sourceZoneId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([fileId])
  @@index([fileVersionId])
}

/// Saved per-user view state for takeoff table (filters, columns, sort, search).
model TakeoffViewPreset {
  id          String  @id @default(cuid())
  workspaceId String
  projectId   String
  userId      String
  name        String
  isDefault   Boolean @default(false)
  configJson  Json

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId, name])
  @@index([workspaceId])
  @@index([projectId, userId])
}

/// Audit trail for drawing -> takeoff sync runs.
model TakeoffSyncRun {
  id                   String    @id @default(cuid())
  workspaceId          String
  projectId            String
  userId               String
  mode                 String
  startedAt            DateTime  @default(now())
  finishedAt           DateTime?
  addedCount           Int       @default(0)
  updatedCount         Int       @default(0)
  removedCount         Int       @default(0)
  sourceFileVersionIds String[]  @default([])
  summaryJson          Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([projectId, createdAt])
}

/// Undo checkpoints for destructive takeoff operations (replace sync, bulk delete).
model TakeoffSnapshot {
  id          String @id @default(cuid())
  workspaceId String
  projectId   String
  userId      String
  reason      String
  payloadJson Json

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([projectId, createdAt])
}

enum RfiStatus {
  OPEN
  IN_REVIEW
  ANSWERED
  CLOSED
}

enum RfiPriority {
  LOW
  MEDIUM
  HIGH
}

/// Many-to-many: one RFI can reference multiple issues; one issue can spawn multiple RFIs.
model RfiIssueLink {
  id        String   @id @default(cuid())
  rfiId     String
  issueId   String
  rfi       Rfi      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([rfiId, issueId])
  @@index([issueId])
  @@index([rfiId])
}

/// Many-to-many: RFI can have multiple designated responders (any can submit the official answer).
model RfiAssigneeLink {
  id        String   @id @default(cuid())
  rfiId     String
  userId    String
  rfi       Rfi      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([rfiId, userId])
  @@index([rfiId])
  @@index([userId])
}

model Rfi {
  id                    String       @id @default(cuid())
  projectId             String
  /// Per-project sequential number for display (#001). Never reused after delete.
  rfiNumber             Int
  project               Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title                 String
  description           String?
  officialResponse      String?
  /// Discussion message designated as the formal answer (plain-text copy also in officialResponse for email/legacy).
  answerMessageId       String?      @unique
  answerMessage         RfiMessage?  @relation("RfiAnswerMessage", fields: [answerMessageId], references: [id], onDelete: SetNull)
  status                RfiStatus    @default(OPEN)
  fromDiscipline        String?
  assignedToUserId      String?
  assignedTo            User?        @relation("RfiAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  creatorId             String?
  creator               User?        @relation("RfiCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  dueDate               DateTime?
  priority              RfiPriority  @default(MEDIUM)
  risk                  String?
  fileId                String?
  file                  File?        @relation("RfiDrawingFile", fields: [fileId], references: [id], onDelete: SetNull)
  fileVersionId         String?
  fileVersion           FileVersion? @relation("RfiDrawingVersion", fields: [fileVersionId], references: [id], onDelete: SetNull)
  pageNumber            Int?
  pinNormX              Float?
  pinNormY              Float?
  voidReason            String?
  lastOverdueNotifiedAt DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  attachments   RfiAttachment[]
  issueLinks    RfiIssueLink[]
  assigneeLinks RfiAssigneeLink[]
  messages      RfiMessage[]

  @@unique([projectId, rfiNumber])
  @@index([projectId])
  @@index([assignedToUserId])
  @@index([creatorId])
}

model RfiAttachment {
  id           String   @id @default(cuid())
  rfiId        String
  rfi          Rfi      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  s3Key        String
  fileName     String
  mimeType     String   @default("application/octet-stream")
  sizeBytes    BigInt
  uploadedById String?
  uploadedBy   User?    @relation("RfiAttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([rfiId])
}

/// In-app discussion thread on an RFI (clarifications before/after official response).
model RfiMessage {
  id        String   @id @default(cuid())
  rfiId     String
  rfi       Rfi      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation("RfiMessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime @default(now())

  officialAnswerForRfi Rfi? @relation("RfiAnswerMessage")

  @@index([rfiId])
}

enum PunchPriority {
  P1
  P2
  P3
}

enum PunchStatus {
  OPEN
  IN_PROGRESS
  READY_FOR_GC
  CLOSED
}

model PunchItem {
  id          String             @id @default(cuid())
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String             @default("Punch item")
  location    String
  trade       String
  priority    PunchPriority      @default(P2)
  status      PunchStatus        @default(OPEN)
  notes       String?
  dueDate     DateTime?
  completedAt DateTime?
  assigneeId  String?
  assignee    User?              @relation("PunchAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  templateId  String?
  template    PunchTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  history     PunchItemHistory[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([templateId])
  @@index([dueDate])
}

model PunchTemplate {
  id          String      @id @default(cuid())
  workspaceId String
  projectId   String?
  name        String
  description String?
  itemsJson   Json        @default("[]")
  isArchived  Boolean     @default(false)
  createdById String?
  createdBy   User?       @relation("PunchTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  punchItems  PunchItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([workspaceId])
  @@index([projectId])
}

model PunchItemHistory {
  id          String    @id @default(cuid())
  punchItemId String
  action      String
  metadata    Json?
  actorUserId String?
  actor       User?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  punchItem   PunchItem @relation(fields: [punchItemId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([punchItemId, createdAt])
}

model FieldReport {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportDate  DateTime
  weather     String?
  authorLabel String?
  photoCount  Int      @default(0)
  issueCount  Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  CHANGE_REQUESTED
}

enum ProposalDeclineReason {
  PRICE_TOO_HIGH
  TIMING
  SCOPE
  OTHER_COMPANY
  OTHER
}

/// Workspace-scoped letter templates with {{variable}} placeholders.
model ProposalTemplate {
  id           String     @id @default(cuid())
  workspaceId  String
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  body         String     @db.Text
  /// e.g. { "taxPercent": 15, "validUntilDays": 14 }
  defaultsJson Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  proposals    Proposal[]

  @@index([workspaceId])
}

/// Sheet revisions whose takeoff lines feed this proposal (order = merge order).
model ProposalTakeoffSource {
  proposalId    String
  fileVersionId String
  sortOrder     Int         @default(0)
  proposal      Proposal    @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  fileVersion   FileVersion @relation(fields: [fileVersionId], references: [id], onDelete: Cascade)

  @@id([proposalId, fileVersionId])
  @@index([fileVersionId])
}

model Proposal {
  id                   String                 @id @default(cuid())
  workspaceId          String
  projectId            String
  createdById          String
  templateId           String?
  sequenceNumber       Int
  reference            String
  title                String
  status               ProposalStatus         @default(DRAFT)
  clientName           String
  clientEmail          String
  clientCompany        String?
  clientPhone          String?
  validUntil           DateTime
  currency             String                 @default("USD")
  subtotal             Decimal                @db.Decimal(19, 2)
  taxPercent           Decimal                @default(0) @db.Decimal(5, 2)
  /// Percent of line-item subtotal added as work / labor before tax (e.g. 15 = 15%).
  workPricePercent     Decimal                @default(0) @db.Decimal(5, 2)
  discount             Decimal                @default(0) @db.Decimal(19, 2)
  total                Decimal                @db.Decimal(19, 2)
  coverNote            String                 @db.Text
  /// Opaque token for client portal; set when sent.
  publicToken          String?                @unique
  signatureData        String?                @db.Text
  signerName           String?
  acceptedAt           DateTime?
  declinedAt           DateTime?
  declineReason        ProposalDeclineReason?
  declineComment       String?
  changeRequestComment String?
  changeRequestedAt    DateTime?
  sentAt               DateTime?
  firstViewedAt        DateTime?
  pdfS3Key             String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  workspace      Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy      User                    @relation("ProposalCreator", fields: [createdById], references: [id], onDelete: Cascade)
  template       ProposalTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  takeoffSources ProposalTakeoffSource[]
  items          ProposalItem[]
  attachments    ProposalAttachment[]
  revisions      ProposalRevision[]
  portalMessages ProposalPortalMessage[]

  @@unique([projectId, sequenceNumber])
  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([workspaceId])
}

model ProposalItem {
  id                  String   @id @default(cuid())
  proposalId          String
  itemName            String
  quantity            Decimal  @db.Decimal(19, 4)
  unit                String
  rate                Decimal  @db.Decimal(19, 4)
  lineTotal           Decimal  @db.Decimal(19, 2)
  sortOrder           Int      @default(0)
  sourceTakeoffLineId String?
  proposal            Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

model ProposalAttachment {
  proposalId    String
  fileVersionId String
  proposal      Proposal    @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  fileVersion   FileVersion @relation(fields: [fileVersionId], references: [id], onDelete: Cascade)

  @@id([proposalId, fileVersionId])
  @@index([fileVersionId])
}

/// Snapshot each time a proposal is sent (Phase 2 revisions / audit).
model ProposalRevision {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sentAt     DateTime @default(now())
  snapshot   Json

  @@index([proposalId, sentAt])
}

/// Token-scoped discussion on the client portal (no login).
model ProposalPortalMessage {
  id           String   @id @default(cuid())
  proposalId   String
  proposal     Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  body         String   @db.Text
  /// true = client (anonymous), false = company reply (requires internal note or future staff portal)
  isFromClient Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([proposalId, createdAt])
}

enum ActivityType {
  WORKSPACE_CREATED
  MEMBER_INVITED
  MEMBER_REMOVED
  PROJECT_CREATED
  FOLDER_CREATED
  FOLDER_DELETED
  FILE_UPLOADED
  FILE_VERSION_ADDED
  FILE_DELETED
  FILE_MOVED
  FOLDER_MOVED
  FILE_OPENED
  ISSUE_CREATED
  ISSUE_UPDATED
  ISSUE_DELETED
  RFI_CREATED
  RFI_UPDATED
  PUNCH_CREATED
  PUNCH_UPDATED
  FIELD_REPORT_CREATED
  FIELD_REPORT_UPDATED
  FIELD_REPORT_DELETED
  RFI_DELETED
  RFI_SENT_FOR_REVIEW
  RFI_RESPONSE_SUBMITTED
  RFI_CLOSED
  RFI_ATTACHMENT_ADDED
  RFI_ATTACHMENT_REMOVED
  RFI_MESSAGE_POSTED
  PUNCH_DELETED
  PROJECT_UPDATED
  SUBSCRIPTION_UPDATED
  STORAGE_THRESHOLD
  PROPOSAL_CREATED
  PROPOSAL_SENT
  PROPOSAL_VIEWED
  PROPOSAL_ACCEPTED
  PROPOSAL_DECLINED
  PROPOSAL_CHANGE_REQUESTED
  PROPOSAL_EXPIRED
  PROPOSAL_RESENT
  PROPOSAL_DELETED
  VIEWER_MARKUP_SAVED
}

model ActivityLog {
  id          String       @id @default(cuid())
  workspaceId String
  /// When set, this event is scoped to a project (audit log / export).
  projectId   String?
  actorUserId String?
  type        ActivityType
  entityType  String?
  entityId    String?
  metadata    Json?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  actor     User?     @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([projectId, createdAt])
}

/// In-app notification (e.g. RFI activity). Shown in the enterprise top bar.
model UserNotification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// e.g. RFI_MESSAGE, RFI_REVIEW, RFI_RESPONSE, RFI_CLOSED
  kind        String
  title       String
  body        String?
  /// In-app path (e.g. /projects/{id}/rfi/{rfiId})
  href        String
  actorUserId String?
  actor       User?     @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// Idempotent Stripe webhook processing
model ProcessedStripeEvent {
  eventId   String   @id
  createdAt DateTime @default(now())
}
