{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "node ./scripts/load-root-env-run-prisma.mjs generate",
    "db:migrate": "node ./scripts/load-root-env-run-prisma.mjs migrate dev && node ./scripts/seed-folder-templates.mjs",
    "db:migrate:deploy": "node ./scripts/load-root-env-run-prisma.mjs migrate deploy && node ./scripts/seed-folder-templates.mjs",
    "db:deploy": "node ./scripts/load-root-env-run-prisma.mjs migrate deploy && node ./scripts/seed-folder-templates.mjs",
    "db:local:generate": "node ./scripts/load-root-env-run-prisma.mjs generate",
    "db:local:push": "node ./scripts/load-root-env-run-prisma.mjs db push && node ./scripts/seed-folder-templates.mjs",
    "db:local:studio": "node ./scripts/load-root-env-run-prisma.mjs studio",
    "db:local:migrate": "node ./scripts/load-root-env-run-prisma.mjs migrate dev && node ./scripts/seed-folder-templates.mjs",
    "db:local:migrate:deploy": "node ./scripts/load-root-env-run-prisma.mjs migrate deploy && node ./scripts/seed-folder-templates.mjs",
    "db:repair-migration-drift": "node ./scripts/repair-migration-drift.mjs",
    "db:prod:generate": "cross-env PRISMA_SKIP_LOCAL=1 node ./scripts/load-root-env-run-prisma.mjs generate",
    "db:prod:push": "cross-env PRISMA_SKIP_LOCAL=1 node ./scripts/load-root-env-run-prisma.mjs db push && cross-env PRISMA_SKIP_LOCAL=1 node ./scripts/seed-folder-templates.mjs",
    "db:prod:studio": "cross-env PRISMA_SKIP_LOCAL=1 node ./scripts/load-root-env-run-prisma.mjs studio",
    "db:prod:migrate:deploy": "cross-env PRISMA_SKIP_LOCAL=1 node ./scripts/load-root-env-run-prisma.mjs migrate deploy && cross-env PRISMA_SKIP_LOCAL=1 node ./scripts/seed-folder-templates.mjs",
    "db:migration-checksum": "node ./scripts/migration-checksum.mjs",
    "db:drift-to-schema": "node ./scripts/drift-to-schema.mjs",
    "db:migrate:baseline": "node ./scripts/baseline-init.mjs",
    "db:baseline": "node ./scripts/baseline-migrations.mjs",
    "db:baseline:prod": "cross-env PRISMA_SKIP_LOCAL=1 node ./scripts/baseline-migrations.mjs",
    "db:migrate:resolve-rolled-back-folder-key": "node ./scripts/load-root-env-run-prisma.mjs migrate resolve --rolled-back 20260330110000_add_file_folder_key",
    "db:push": "node ./scripts/load-root-env-run-prisma.mjs db push && node ./scripts/seed-folder-templates.mjs",
    "db:seed": "node ./scripts/load-root-env-run-prisma.mjs db seed",
    "db:seed:templates": "node ./scripts/seed-folder-templates.mjs",
    "db:backfill-project-dates": "tsx scripts/backfill-project-dates.ts",
    "db:studio": "node ./scripts/load-root-env-run-prisma.mjs studio",
    "db:validate": "node ./scripts/load-root-env-run-prisma.mjs validate",
    "db:precommit": "node ./scripts/load-root-env-run-prisma.mjs validate && node ./scripts/load-root-env-run-prisma.mjs format && node ./scripts/load-root-env-run-prisma.mjs generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.787.0",
    "@aws-sdk/s3-request-presigner": "^3.787.0",
    "@better-auth/prisma-adapter": "^1.4.7",
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.19.5",
    "@hono/node-ws": "^1.3.0",
    "@prisma/client": "^6.19.0",
    "better-auth": "^1.4.7",
    "dotenv": "^16.6.1",
    "hono": "^4.11.3",
    "marked": "^15.0.12",
    "pdfkit": "^0.18.0",
    "resend": "^4.0.0",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.5",
    "stripe": "^18.0.0",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.5",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "prisma": "^6.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.2.4"
  }
}
